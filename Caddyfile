# www-Variante auf Apex umleiten (Refs #801).
www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}

{$DOMAIN} {
    reverse_proxy web:8000

    # Defense-in-Depth gegen Disk-Fill/OOM (Refs #1363, N10 + Review-Nachschlag):
    # weist Request-Bodies oberhalb der App-seitigen Obergrenze schon am Edge
    # ab, bevor sie den Gunicorn-Worker erreichen. Dimensioniert fuer EIN
    # volles Multi-File-Feld: ``FILE_VAULT_MAX_UPLOAD_BYTES`` (Default 50 MiB)
    # * ``FILE_VAULT_MAX_UPLOAD_FILES`` (Default 20 Dateien/Feld,
    # MultipleFileInput/Refs #622) = 1000 MiB, + 10 % Marge fuer
    # Multipart-Overhead (Boundaries, Feld-Header, CSRF-Token u.ae.) = 1100 MiB.
    # Ein kleinerer, nur auf EINE Datei dimensionierter Cap weist legitime
    # Multi-File-Uploads (bereits unterstuetztes Feature) am Edge mit 413 ab,
    # obwohl jede einzelne Datei alle App-seitigen Checks bestehen wuerde.
    # WICHTIG: rein statisch, folgt NICHT automatisch einer per Env
    # ueberschriebenen ``FILE_VAULT_MAX_UPLOAD_BYTES``/``FILE_VAULT_MAX_UPLOAD_FILES``
    # — bei Aenderung eines der beiden App-Limits diesen Wert manuell
    # nachziehen und Caddy neu laden (docs/ops-runbook.md § 5.7).
    # Restrisiko (dokumentiert, nicht gefixt): ein DocumentType KANN mehrere
    # FILE-Felder tragen (nur von facility_admin/super_admin konfigurierbar)
    # — dann steigt der theoretische Worst-Case je zusaetzlichem Feld um
    # weitere 1000 MiB. Test-Guard: test_architecture_guards_ops.py::TestCaddyUploadBodyLimit.
    request_body {
        max_size 1100MiB
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        # X-Robots-Tag (A7.4, Refs #1024): Anlaufstelle ist eine geschlossene
        # Fachsoftware mit sensiblen Daten — keine Suchmaschinen-Indizierung
        # erwünscht (gilt auch für Staging/Dev-Deployments). Default noindex/
        # nofollow; per X_ROBOTS_TAG-Env überschreibbar, falls je gewünscht.
        X-Robots-Tag "{$X_ROBOTS_TAG:noindex, nofollow}"
        # CSP wird ausschließlich über Django-CSP-Middleware gesteuert (settings/base.py)
    }

    # Access-Log nach /var/log/caddy/access.log (Container-Pfad). Der
    # Operator mountet das Verzeichnis als Volume in docker-compose.prod.yml,
    # damit Logs den Container-Restart ueberleben. Refs #801.
    log {
        output file /var/log/caddy/access.log {
            roll_size 10MiB
            roll_keep 10
            roll_keep_for 720h
        }
        format json
    }

    # Optionaler Rate-Limit (Defense-in-Depth gegen Login-/API-Brute-Force).
    # Standardmaessig nicht aktiv, da Caddy ohne Plugin keine Rate-Limits
    # unterstuetzt. Operatoren, die einen Limit benoetigen, koennen
    # caddy-ratelimit (https://github.com/mholt/caddy-ratelimit) als Modul
    # in ein eigenes Caddy-Image bauen und z. B. folgendes ergaenzen:
    #
    #     rate_limit {
    #         zone login_zone {
    #             key {http.request.remote_host}
    #             events 10
    #             window 1m
    #         }
    #         match {
    #             path /login/* /accounts/* /api/*
    #         }
    #     }
    #
    # Siehe docs/coolify-deployment.md.
}
