# Vorlage fuer .env.dev (Refs #671). Kopiere diese Datei nach
# /opt/anlaufstelle/.env.dev auf dem Server, fuelle die Werte und setze
# chmod 600. .env.dev wird NICHT in git committed.

# === Caddy / TLS ===
# Domain: muss als A/AAAA auf den Server zeigen.
DOMAIN=dev.anlaufstelle.app
# Let's-Encrypt-Account-Mail (Renewal-Notifications).
ACME_EMAIL=kontakt@anlaufstelle.app

# === Django (Pflicht — devlive.py erbt von prod.py) ===
# 64 zufaellige Bytes, z.B.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Komma-separiert; muss die oeffentliche Domain enthalten.
ALLOWED_HOSTS=dev.anlaufstelle.app

# Verschluesselungs-Key fuer encrypted-fields (Plural fuer Rotation).
# Verlust = alle verschluesselten Felder (Notes, Attachments, …) sind weg.
# Im Passwortmanager hinterlegen.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Optional: ENCRYPTION_KEYS=key1,key2 fuer Rotation.

# Separater HMAC-Key fuer Audit-Hashes (Refs #791).
# Empfohlen, sonst Fallback auf SECRET_KEY-Derivat.
DJANGO_AUDIT_HASH_KEY=

# === PostgreSQL ===
# Drei User trennen Bootstrap, Runtime und Wartung. Refs #671, #863,
# ADR-005 § 2-User-Modell.
POSTGRES_DB=anlaufstelle
# App-User (NOSUPERUSER, NOBYPASSRLS) — Django Runtime.
# Wird vom Init-Script angelegt; RLS-Policies greifen gegen diesen User.
POSTGRES_USER=anlaufstelle
POSTGRES_PASSWORD=
# Admin-User (NOSUPERUSER, BYPASSRLS) — fuer seed/migrate/Wartung.
# Wird vom Init-Script angelegt. Operator-Tasks connecten als dieser User.
POSTGRES_ADMIN_USER=anlaufstelle_admin
POSTGRES_ADMIN_PASSWORD=
# Bootstrap-Superuser (=postgres) — Init-Phase + Notfall.
# Im Passwortmanager hinterlegen, NICHT fuer Runtime nutzen.
POSTGRES_BOOTSTRAP_PASSWORD=
POSTGRES_PORT=5432

# === ClamAV (default an in prod-erbenden Settings) ===
CLAMAV_ENABLED=true
CLAMAV_PORT=3310

# === Optional ===
# Sentry-DSN (leer = Sentry inaktiv). Nachtraeglich befuellen, dann
# `docker compose -f docker-compose.dev.yml --env-file .env.dev up -d web`.
SENTRY_DSN=

# Quellcode-Link im Footer (AGPL §13). Default zeigt auf das public app-Repo.
# Bei eigenen Forks muss der Link auf den eigenen Spiegel zeigen.
SOURCE_CODE_URL=https://github.com/anlaufstelle/app
SOURCE_CODE_VERSION=

# === Backup (deploy/backup.sh) ===
# Verschluesselungs-Key fuer pg_dump. Im Passwortmanager hinterlegen.
BACKUP_ENCRYPTION_KEY=
# Verzeichnis fuer Daily-Dumps (auf dem Server).
BACKUP_DIR=/var/backups/anl
# Aufbewahrung in Tagen.
BACKUP_RETENTION_DAYS=14
