# Vorlage fuer .env.demo (Refs #1062). Kopiere nach
# /opt/anlaufstelle/.env.demo auf der Demo-VPS, fuelle die Werte und setze
# chmod 600. .env.demo wird NICHT in git committed.
#
# Oeffentliche Demo mit synthetischen Daten + stuendlichem Seed-Reset.

# === Caddy / TLS ===
DOMAIN=demo.anlaufstelle.app
ACME_EMAIL=kontakt@anlaufstelle.app

# === Django (Pflicht — demo.py erbt von devlive/prod) ===
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# localhost/127.0.0.1 noetig fuer den Container-Healthcheck
# (http://localhost:8000/health/) — prod.py baut ALLOWED_HOSTS rein aus dieser
# Variable, ohne localhost wirft /health/ einen DisallowedHost-400.
ALLOWED_HOSTS=demo.anlaufstelle.app,localhost,127.0.0.1

# Verschluesselungs-Key. Demo-Daten sind synthetisch + werden stuendlich
# resettet -> Key-Verlust unkritisch, aber muss gesetzt sein (prod-Vererbung).
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# HMAC-Key fuer Audit-Hashes (Refs #791).
DJANGO_AUDIT_HASH_KEY=

# === PostgreSQL (Drei-Rollen-Modell) ===
POSTGRES_DB=anlaufstelle
POSTGRES_USER=anlaufstelle
POSTGRES_PASSWORD=
POSTGRES_ADMIN_USER=anlaufstelle_admin
POSTGRES_ADMIN_PASSWORD=
POSTGRES_BOOTSTRAP_PASSWORD=
POSTGRES_PORT=5432

# === ClamAV (Pflicht — oeffentliche Upload-Demo) ===
CLAMAV_ENABLED=true
CLAMAV_PORT=3310

# === Optional ===
SENTRY_DSN=
SOURCE_CODE_URL=https://github.com/anlaufstelle/app
SOURCE_CODE_VERSION=

# === Backup ===
# Demo braucht kein echtes Backup (synthetisch + stuendlicher Reset).
# BACKUP_DIR bleibt fuer die Health-Card gesetzt; Backup-Cron wird NICHT
# installiert.
BACKUP_DIR=/var/backups/anl
