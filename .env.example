# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_SETTINGS_MODULE=anlaufstelle.settings.prod

# PostgreSQL
POSTGRES_DB=anlaufstelle
POSTGRES_USER=anlaufstelle
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Required in production. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECURITY: chmod 600 .env to restrict access
ENCRYPTION_KEY=
#
# Key-Rotation (MultiFernet): komma-getrennte Liste von Fernet-Keys.
# Der erste Key wird zum Verschlüsseln verwendet, alle Keys zum Entschlüsseln.
# Beispiel: ENCRYPTION_KEYS=neuer-key,alter-key
# Wenn ENCRYPTION_KEYS gesetzt ist, wird ENCRYPTION_KEY ignoriert.
ENCRYPTION_KEYS=

# Produktion
ALLOWED_HOSTS=anlaufstelle.app,www.anlaufstelle.app

# Caddy (Domain für Auto-TLS)
DOMAIN=anlaufstelle.app

# Sentry (optional — Error-Tracking, nur in Produktion)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# JSON-Logging aktivieren (Standard: text)
# LOG_FORMAT=json

# Gunicorn-Konfiguration
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=30

# Backup-Verschlüsselung
BACKUP_ENCRYPTION_KEY=change-me-to-a-random-string

# E-Mail / SMTP (für Passwort-Reset und Token-Invite-Flow, Refs #528)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@anlaufstelle.app

# Media-Root für verschlüsselte Datei-Anhänge (Encrypted File Vault)
# Sollte auf persistentem Volume liegen, außerhalb des Image-Baums.
MEDIA_ROOT=/data/media

# ClamAV-Virenscan für File Vault (Refs #524)
# In Produktion standardmäßig aktiv. Nur auf "false" setzen, wenn kein ClamAV-Container läuft.
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# TRUSTED_PROXY_HOPS — Anzahl Proxy-Hops zwischen Client und App (Refs #523)
# 0 = direkter Zugriff, 1 = Caddy-only (Default), 2 = CDN + Caddy (z.B. Cloudflare)
TRUSTED_PROXY_HOPS=1
